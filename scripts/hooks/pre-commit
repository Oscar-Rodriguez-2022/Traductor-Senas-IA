#!/bin/sh
# pre-commit: bloquea secretos antes de que lleguen al repositorio
# Proyecto: LSP Vision AI — UPN Capstone 2026

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

ERRORS=0

echo "[ pre-commit ] Escaneando secretos en archivos staged..."

# ─────────────────────────────────────────────
# 1. ARCHIVOS BLOQUEADOS POR NOMBRE
# ─────────────────────────────────────────────
BLOCKED_NAMES="secrets.toml|\.env$|\.env\.|audit_log\.jsonl|\.pem$|\.key$|\.p12$|\.pfx$|id_rsa|id_ed25519|credentials\.json|serviceAccountKey\.json"

STAGED_FILES=$(git diff --cached --name-only)

for FILE in $STAGED_FILES; do
    BASENAME=$(basename "$FILE")
    if echo "$BASENAME" | grep -qE "$BLOCKED_NAMES"; then
        printf "${RED}[BLOQUEADO]${NC} Archivo sensible en staging: %s\n" "$FILE"
        ERRORS=$((ERRORS + 1))
    fi
done

# ─────────────────────────────────────────────
# 2. PATRONES DE CONTENIDO SOSPECHOSO
#    Se escanea solo el diff staged (no el repo entero)
# ─────────────────────────────────────────────
SECRET_PATTERNS="password\s*=\s*['\"][^'\"]{4,}['\"]|\
api[_-]?key\s*=\s*['\"][^'\"]{8,}['\"]|\
secret[_-]?key\s*=\s*['\"][^'\"]{8,}['\"]|\
token\s*=\s*['\"][^'\"]{8,}['\"]|\
APP_PASSWORD\s*=|\
-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----|\
AKIA[0-9A-Z]{16}|\
ghp_[0-9A-Za-z]{36}|\
sk-[0-9A-Za-z]{48}"

DIFF_CONTENT=$(git diff --cached --unified=0)
ADDED_LINES=$(echo "$DIFF_CONTENT" | grep -E "^\+" | grep -v "^+++")
MATCH=$(echo "$ADDED_LINES" | grep -iE "$SECRET_PATTERNS" 2>/dev/null)

if [ -n "$MATCH" ]; then
    printf "${RED}[BLOQUEADO]${NC} Patron de secreto detectado en el diff:\n"
    echo "$MATCH" | head -5 | sed 's/^/  /'
    ERRORS=$((ERRORS + 1))
fi

# ─────────────────────────────────────────────
# 3. ARCHIVOS .TOML/.ENV CON CLAVES EN TEXTO
# ─────────────────────────────────────────────
for FILE in $STAGED_FILES; do
    case "$FILE" in
        *.toml|*.env|*.cfg|*.ini|*.yaml|*.yml)
            CONTENT=$(git show ":$FILE" 2>/dev/null)
            MATCH=$(echo "$CONTENT" | grep -iE "password\s*=\s*['\"][^'\"]{4,}['\"]|secret\s*=\s*['\"][^'\"]{4,}['\"]" 2>/dev/null)
            if [ -n "$MATCH" ]; then
                printf "${YELLOW}[ADVERTENCIA]${NC} Posible secreto en %s:\n" "$FILE"
                echo "$MATCH" | head -3 | sed 's/^/  /'
                ERRORS=$((ERRORS + 1))
            fi
            ;;
    esac
done

# ─────────────────────────────────────────────
# RESULTADO
# ─────────────────────────────────────────────
if [ "$ERRORS" -gt 0 ]; then
    printf "\n${RED}Commit bloqueado: %d problema(s) encontrado(s).${NC}\n" "$ERRORS"
    echo ""
    echo "  Para desbloquear (solo si estas SEGURO de que no son secretos reales):"
    echo "    git commit --no-verify"
    echo ""
    echo "  Para sacar un archivo del staging sin borrarlo:"
    echo "    git rm --cached <archivo>"
    echo "    echo '<archivo>' >> .gitignore"
    echo ""
    exit 1
fi

printf "${GREEN}[ pre-commit ] Sin secretos detectados. Commit permitido.${NC}\n"
exit 0
